# ═══════════════════════════════════════════
# DineSmart OS — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════

# ── Database ──────────────────────────────
DATABASE_URL=postgresql://dinesmart:dinesmart_secret@localhost:5432/dinesmart?schema=public

# ── Redis ─────────────────────────────────
REDIS_URL=redis://red-d7hf8ntckfvc73eiibk0:6379

# ── Server ────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_CUSTOMER_URL=http://localhost:5173
FRONTEND_STAFF_URL=http://localhost:5174
FRONTEND_SUPERADMIN_URL=http://localhost:5175

# ── JWT Secrets ───────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-here
JWT_SUPERADMIN_SECRET=your-superadmin-secret-min-32-chars-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CSRF ──────────────────────────────────
CSRF_SECRET=your-csrf-secret-min-32-chars-long-here

# ── Razorpay ──────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Cloudinary ────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (Resend) ────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@dinesmart.app

# ── SMTP Fallback (Nodemailer) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── QR Code Base URL ─────────────────────
QR_BASE_URL=https://dinesmart.app

# ── Logging ───────────────────────────────
LOG_LEVEL=debug
