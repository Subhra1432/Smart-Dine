{
  "name": "dinesmart-os",
  "version": "1.0.0",
  "private": true,
  "description": "DineSmart OS — Complete Multi-Tenant SaaS Restaurant Operating System",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "dev:api": "npm run dev -w packages/api",
    "dev:customer": "npm run dev -w apps/customer",
    "dev:staff": "npm run dev -w apps/staff",
    "dev:desktop": "npm run start -w apps/desktop",
    "dev:superadmin": "npm run dev -w apps/superadmin",
    "build": "npm run build:all",
    "build:shared": "npm run build -w packages/shared",
    "build:api": "npm run build -w packages/api",
    "build:customer": "npm run build -w apps/customer",
    "build:staff": "npm run build -w apps/staff",
    "build:desktop": "npm run build:win -w apps/desktop",
    "build:superadmin": "npm run build -w apps/superadmin",
    "build:all": "npm run build:shared && npm run build:api && npm run build:customer && npm run build:staff && npm run build:superadmin",
    "start:prod": "node packages/api/dist/app.js",
    "db:generate": "npm run db:generate -w packages/api",
    "db:push": "npm run db:push -w packages/api",
    "db:migrate": "npm run db:migrate -w packages/api",
    "db:seed": "npm run db:seed -w packages/api",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "electron": "^42.0.1",
    "google-auth-library": "^10.6.2"
  }
}
